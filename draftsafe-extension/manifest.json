{
  "manifest_version": 3,
  "name": "DraftSafe AI",
  "version": "1.2",
  "description": "Autonomous AI protection for your email and social drafts.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*", 
        "https://www.linkedin.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}